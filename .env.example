# Supabase Auth (URL + anon: Cursor MCP tools get_project_url / get_publishable_keys, atau Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Screenshot / file upload (server only — jangan expose ke client). Buat bucket di Dashboard → Storage.
# Untuk Supabase Storage, ketiga env ini harus diisi bersama:
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_STORAGE_BUCKET="portfolio-screenshots"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# PostgreSQL (lokal atau layanan apa pun yang kompatibel)
DATABASE_URL="postgresql://portfolio:portfolio@127.0.0.1:5432/portfolio"
# Jika Supabase host db.* tidak terjangkau (P1001), coba URI "Session pooler" dari Dashboard (host *.pooler.supabase.com:5432).

# Supabase / pooler (opsional)
# - Untuk aplikasi di serverless atau banyak koneksi singkat: pakai connection string "pooling"
#   (Supabase biasanya host ...pooler.supabase.com, port 6543) dan tambahkan ?pgbouncer=true
#   (sesuaikan dengan string yang ditampilkan dashboard Supabase).
# - Jalankan migrasi Prisma ke koneksi langsung: set DIRECT_URL ke URI "direct" (port 5432,
#   host db.<project>.supabase.co) dengan sslmode=require. Biarkan DATABASE_URL = pooler untuk runtime.
# - Satu VM + worker: cukup satu direct DATABASE_URL; DIRECT_URL tidak perlu.
# DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require"

# Optional
# REDIS_URL="redis://127.0.0.1:6379"

# Penyimpanan file screenshot (pilih salah satu; wajib cloud di Vercel)
# A) Supabase Storage: set NEXT_PUBLIC_SUPABASE_URL + SUPABASE_STORAGE_BUCKET + SUPABASE_SERVICE_ROLE_KEY di atas
# B) S3 / R2 / Supabase S3-compatible: set STORAGE_DRIVER=s3 lalu isi S3_* di bawah
#    Contoh Supabase S3-compatible: S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
#    Region Supabase S3-compatible biasanya pakai region project Anda (mis. ap-southeast-1)
# Lokal dev tanpa env storage: pakai folder storage/uploads
# STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Opsional jika ingin override jalur Pro
# GEMINI_PRO_MODEL="gemini-2.5-pro"

# Admin (koma = beberapa email, sinkron ke role ADMIN di Postgres saat login)
ADMIN_EMAILS=""

# Stripe Billing (opsional — checkout + webhook; bisa diabaikan jika hanya pakai Midtrans)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Fallback harga Pro jika kolom Plan.stripePriceId kosong:
STRIPE_PRO_PRICE_ID=""

# Midtrans Snap (pembayaran Indonesia)
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION=false
# Kode paket Pro default jika Plan.midtransPackageCode kosong
MIDTRANS_PRO_PACKAGE_CODE=""
# Harga default paket Pro (rupiah, integer)
MIDTRANS_PRO_AMOUNT=49000

# URL publik app (untuk origin checkout bila header Origin tidak ada, SEO canonical/sitemap/OG)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
